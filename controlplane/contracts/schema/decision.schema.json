{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raccoonrat.dev/cnais/decision.schema.json",
  "title": "DecisionContract",
  "description": "The only enforcement input (INV-3). Spec v1.6 §11 + §1.4 + §6.2 additions.",
  "type": "object",
  "required": ["schema_version", "decision_id", "trace_id", "context_id", "stage", "decision"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "1.6" },
    "decision_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "context_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "stage": { "enum": ["input", "retrieval", "tool_pre_execution", "output"] },
    "subject": { "type": "object" },
    "object": { "type": "object" },
    "signals": { "type": "array", "items": { "type": "object" } },
    "fused_risk_summary": { "type": "object" },
    "policy": { "type": "object" },
    "decision": {
      "type": "object",
      "required": ["action", "reason_code"],
      "properties": {
        "action": {
          "enum": ["allow", "deny", "block", "redact", "sanitize", "mask", "restrict_scope",
                   "require_confirmation", "require_review", "step_up_auth", "audit_only", "annotate_risk"]
        },
        "reason_code": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "decision_mode": { "enum": ["shadow", "canary", "prod"] },
        "enforcement_required": { "type": "boolean" },
        "stability": { "enum": ["final", "provisional_pending_async"] },
        "decision_revision": { "type": "integer", "minimum": 0 },
        "supersedes_decision_id": { "type": "string" }
      }
    },
    "constraints": { "type": "object" },
    "approval_binding": { "type": "object" },
    "evidence": { "type": "object" },
    "replay_binding": {
      "type": "object",
      "properties": {
        "context_snapshot_ref": { "type": "string" },
        "signal_snapshot_refs": { "type": "array", "items": { "type": "string" } },
        "policy_bundle_version": { "type": "string" },
        "fusion_config_version": { "type": "string" },
        "threshold_config_version": { "type": "string" },
        "matrix_version": { "type": "string" },
        "provenance_mode": { "enum": ["MODE_A", "MODE_B"] },
        "dropped_signals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_id": { "type": "string" },
              "reason": { "enum": ["registry_miss", "signature_invalid", "expired"] }
            }
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "decision_hash": { "type": "string" },
        "signed_by": { "type": "string" },
        "signature": { "type": "string" }
      }
    }
  }
}
