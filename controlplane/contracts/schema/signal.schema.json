{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raccoonrat.dev/cnais/signal.schema.json",
  "title": "Signal",
  "description": "Structured security signal. Signal is NOT a decision (INV-1). Provenance must be verifiable (INV-7).",
  "type": "object",
  "required": ["schema_version", "signal_id", "trace_id", "stage", "risk_family", "severity", "source"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "1.6" },
    "signal_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "context_id": { "type": "string" },
    "stage": { "enum": ["input", "retrieval", "tool_pre_execution", "output"] },
    "signal_type": {
      "enum": ["prompt_injection", "pii", "enterprise_data_leakage", "unsafe_content",
               "tool_schema_drift", "tool_manifest_drift", "unauthorized_action",
               "policy_violation", "source_untrusted", "approval_stale", "registry_miss",
               "signal_integrity_violation"]
    },
    "risk_family": { "enum": ["SEC", "SAF", "PRIV", "REL", "COMP"] },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "created_at": { "type": "string", "format": "date-time" },
    "ttl_ms": { "type": "integer", "minimum": 0 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "source": {
      "type": "object",
      "required": ["source_id", "source_type"],
      "properties": {
        "source_id": { "type": "string" },
        "source_type": { "enum": ["rule", "model", "judge", "trust", "schema", "registry", "human", "system"] },
        "source_version": { "type": "string" }
      }
    },
    "attributes": {
      "type": "object",
      "properties": {
        "data_asset_type": { "type": "string" },
        "data_sensitivity": { "type": "string" },
        "destination_boundary": { "type": "string" },
        "tool_id": { "type": "string" },
        "server_id": { "type": "string" },
        "matched_pattern": { "type": "string" },
        "reason_summary": { "type": "string" },
        "advisory_only": { "type": "boolean" },
        "span_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "integrity": {
      "type": "object",
      "description": "INV-7. signature required in MODE-B.",
      "properties": {
        "signature": { "type": "string" },
        "key_id": { "type": "string" },
        "signed_payload_hash": { "type": "string" }
      }
    },
    "evidence_ref": { "type": "string" },
    "evidence_pending": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "source": { "properties": { "source_type": { "const": "judge" } } } } },
      "then": {
        "properties": {
          "attributes": { "required": ["advisory_only"], "properties": { "advisory_only": { "const": true } } }
        }
      }
    }
  ]
}
